---
import { siteUrl } from "../utils/siteUrl";

const { lang = "en" } = Astro.props;
const isEn = lang === "en";
const prefix = isEn ? "en" : "id";
const toggleHref = siteUrl(isEn ? "id/" : "en/");
const toggleLabel = isEn ? "ID" : "EN";
---

<header class="sticky top-0 z-50 border-b border-red-100 bg-zinc-100/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-4 py-4">
    <a href={siteUrl(`${prefix}/`)} class="flex items-center gap-1.5">
      <img
        src={siteUrl("base44_product_image/IMC_Logo.png")}
        alt="Indah Machine logo"
        class="h-10 w-auto"
        loading="lazy"
      />
      <span class="hidden text-lg font-bold leading-none text-red-700 sm:inline">
        Indah Machine
      </span>
    </a>
    <nav class="flex items-center gap-4 text-sm font-medium">
      <a href={siteUrl(`${prefix}/`)} class="text-zinc-700 hover:text-red-700">
        {isEn ? "Home" : "Beranda"}
      </a>
      <a href={siteUrl(`${prefix}/products`)} class="text-zinc-700 hover:text-red-700">
        {isEn ? "Products" : "Produk"}
      </a>
      <a href={siteUrl(`${prefix}/about`)} class="text-zinc-700 hover:text-red-700">
        {isEn ? "About" : "Tentang"}
      </a>
      <a href={siteUrl(`${prefix}/contact`)} class="text-zinc-700 hover:text-red-700">
        {isEn ? "Contact" : "Kontak"}
      </a>
      <a
        href={toggleHref}
        class="rounded-full border border-red-300 px-3 py-1 text-xs font-semibold text-red-700 hover:bg-red-50"
      >
        {toggleLabel}
      </a>
      <a
        href={siteUrl(`${prefix}/contact`)}
        class="hidden rounded-full bg-red-600 px-4 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-red-500 sm:inline"
      >
        {isEn ? "Request Quote" : "Minta Penawaran"}
      </a>
    </nav>
  </div>
</header>

