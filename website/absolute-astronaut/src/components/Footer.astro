---
const { lang = "en" } = Astro.props;
const isEn = lang === "en";
const base = isEn ? "/en" : "/id";
---

<footer class="bg-zinc-900 text-zinc-400">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-12 md:grid-cols-3">

      <!-- Col 1: Brand -->
      <div class="space-y-4">
        <a href={base + "/"} class="inline-flex rounded-2xl bg-zinc-100 px-3 py-2 shadow-sm">
          <img
            src="/base44_product_image/IMC_Logo.png"
            alt="Indah Machine logo"
            class="h-10 w-auto"
            loading="lazy"
          />
        </a>
        <p class="text-sm leading-relaxed">
          {isEn
            ? "Industrial machinery distributor serving Medan, Jakarta & Surabaya. Alternators, electric motors, and power presses."
            : "Distributor mesin industri melayani Medan, Jakarta & Surabaya. Alternator, motor listrik, dan power press."}
        </p>
        <address class="not-italic text-xs leading-relaxed text-zinc-500">
          Jln. Mangkubumi No. 12<br />
          Medan 20151, {isEn ? "North Sumatra" : "Sumatera Utara"}, Indonesia
        </address>
      </div>

      <!-- Col 2: Navigation -->
      <div class="space-y-4">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-zinc-300">
          {isEn ? "Navigation" : "Navigasi"}
        </h3>
        <nav class="flex flex-col gap-2 text-sm">
          <a href={base + "/"} class="hover:text-white transition-colors">
            {isEn ? "Home" : "Beranda"}
          </a>
          <a href={base + "/products"} class="hover:text-white transition-colors">
            {isEn ? "Products" : "Produk"}
          </a>
          <a href={base + "/about"} class="hover:text-white transition-colors">
            {isEn ? "About" : "Tentang"}
          </a>
          <a href={base + "/contact"} class="hover:text-white transition-colors">
            {isEn ? "Contact" : "Kontak"}
          </a>
        </nav>
      </div>

      <!-- Col 3: Contact -->
      <div class="space-y-4">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-zinc-300">
          {isEn ? "Contact" : "Kontak"}
        </h3>
        <div class="flex flex-col gap-2 text-sm">
          <a href="mailto:indahmachine@gmail.com" class="hover:text-white transition-colors">
            indahmachine@gmail.com
          </a>
          <a href="tel:+6285348674326" class="hover:text-white transition-colors">
            +62 85-34-867-4326
          </a>
          <a href="tel:+628163006825" class="hover:text-white transition-colors">
            +62 81-630-6825
          </a>
          <a
            href="https://wa.me/6285348674326"
            class="mt-1 inline-flex items-center gap-1.5 text-emerald-400 hover:text-emerald-300 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>

    </div>

    <div class="mt-12 border-t border-zinc-800 pt-6 text-xs text-zinc-600">
      © {new Date().getFullYear()} Indah Machine. {isEn ? "All rights reserved." : "Hak cipta dilindungi."}
    </div>
  </div>
</footer>
