---
import { siteUrl } from "../utils/siteUrl";
import { products, seriesListingProducts, type Product } from "../data/products";

export interface FaqItem {
  q: string;
  a: string;
}

export interface KeywordLandingCrossLink {
  label: string;
  href: string;
}

export interface Props {
  lang: "en" | "id";
  /** Pre-title eyebrow text (e.g. "Indonesia" or "Medan, Indonesia") */
  eyebrow: string;
  h1: string;
  intro: string;
  /** Product IDs to feature. If omitted, falls back to family filter. */
  productIds?: string[];
  /** When productIds is empty, filter by these families. */
  productFamilies?: Array<Product["family"]>;
  /** Section heading shown above the product grid. */
  productsHeading: string;
  /** Section heading for industries. */
  industriesHeading: string;
  industries: { title: string; body: string }[];
  /** Section heading for the trust / why band. */
  trustHeading: string;
  trustBody: string;
  /** Coverage / shipping section (used by city pages; pass null to hide). */
  coverageHeading?: string | null;
  coverageBody?: string | null;
  /** FAQ section. */
  faqHeading: string;
  faqs: FaqItem[];
  /** "See also" cross-links rendered above the final CTA. */
  crossLinksHeading?: string | null;
  crossLinks?: KeywordLandingCrossLink[];
  ctaHeading: string;
  ctaBody: string;
  ctaButtonLabel: string;
  ctaHref: string;
}

const {
  lang,
  eyebrow,
  h1,
  intro,
  productIds,
  productFamilies,
  productsHeading,
  industriesHeading,
  industries,
  trustHeading,
  trustBody,
  coverageHeading = null,
  coverageBody = null,
  faqHeading,
  faqs,
  crossLinksHeading = null,
  crossLinks = [],
  ctaHeading,
  ctaBody,
  ctaButtonLabel,
  ctaHref,
} = Astro.props as Props;

const productPathPrefix = lang === "en" ? "en/products" : "id/products";
const viewLabel = lang === "en" ? "View details" : "Lihat detail";

let featuredProducts: Product[] = [];
if (productIds && productIds.length > 0) {
  const byId = new Map(products.map((p) => [p.id, p]));
  featuredProducts = productIds
    .map((id) => byId.get(id))
    .filter((p): p is Product => Boolean(p));
} else if (productFamilies && productFamilies.length > 0) {
  featuredProducts = seriesListingProducts.filter((p) => productFamilies.includes(p.family));
}
const productsToShow = featuredProducts.slice(0, 6);
---

<main class="bg-zinc-100 text-zinc-900">

  <!-- Hero -->
  <section class="bg-zinc-50 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-red-600">{eyebrow}</p>
      <h1 class="mt-3 text-4xl font-semibold leading-tight tracking-tight text-zinc-900 sm:text-5xl">
        {h1}
      </h1>
      <p class="mt-5 max-w-3xl text-base leading-relaxed text-zinc-600 sm:text-lg" set:html={intro} />
      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href={ctaHref}
          class="rounded-full bg-red-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-red-500 transition-colors"
        >
          {ctaButtonLabel}
        </a>
        <a
          href="https://wa.me/6285348674326"
          class="rounded-full border border-emerald-300 px-6 py-2.5 text-sm font-semibold text-emerald-700 hover:bg-emerald-50 transition-colors"
        >
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Featured products -->
  {productsToShow.length > 0 && (
    <section class="bg-zinc-100 py-16">
      <div class="mx-auto max-w-6xl px-4">
        <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">
          {productsHeading}
        </h2>
        <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {productsToShow.map((p) => (
            <a
              href={siteUrl(`${productPathPrefix}/${encodeURIComponent(p.id)}`)}
              class="group flex flex-col overflow-hidden rounded-2xl border border-zinc-200 shadow-sm transition hover:border-red-300 hover:shadow-md"
            >
              <div class="flex aspect-[4/3] w-full items-center justify-center bg-white p-3">
                <img
                  src={siteUrl(p.image_path.replace(/^\/+/, ""))}
                  alt={`${p.name} | ${p.family} ${lang === "en" ? "Indonesia" : "Indonesia"}`}
                  class="max-h-full max-w-full object-contain transition duration-300 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </div>
              <div class="flex flex-1 flex-col justify-between bg-zinc-100 p-5">
                <div class="space-y-1">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-500">
                    {p.family} · {p.series}
                  </p>
                  <h3 class="text-base font-semibold text-zinc-900 line-clamp-2">{p.name}</h3>
                </div>
                <p class="mt-3 text-xs leading-relaxed text-zinc-500 line-clamp-3">{p.description}</p>
                <p class="mt-4 text-xs font-semibold text-red-600 group-hover:text-red-500">
                  {viewLabel} →
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Industries -->
  {industries.length > 0 && (
    <section class="bg-zinc-50 py-16">
      <div class="mx-auto max-w-6xl px-4">
        <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">
          {industriesHeading}
        </h2>
        <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {industries.map((it) => (
            <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
              <h3 class="text-base font-semibold text-zinc-900">{it.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-zinc-600">{it.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Coverage / shipping (city pages) -->
  {coverageHeading && coverageBody && (
    <section class="bg-zinc-100 py-16">
      <div class="mx-auto max-w-4xl px-4">
        <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">
          {coverageHeading}
        </h2>
        <p class="mt-5 text-base leading-relaxed text-zinc-600" set:html={coverageBody} />
      </div>
    </section>
  )}

  <!-- Trust band -->
  <section class="bg-zinc-900 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-2xl font-semibold leading-tight tracking-tight text-white sm:text-3xl">
        {trustHeading}
      </h2>
      <p class="mt-5 text-base leading-relaxed text-zinc-400">{trustBody}</p>
    </div>
  </section>

  <!-- FAQ -->
  {faqs.length > 0 && (
    <section class="bg-zinc-50 py-16">
      <div class="mx-auto max-w-3xl px-4">
        <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">
          {faqHeading}
        </h2>
        <div class="mt-8 space-y-3">
          {faqs.map((it) => (
            <details class="group rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm open:border-red-200">
              <summary class="cursor-pointer list-none text-base font-semibold text-zinc-900">
                {it.q}
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-zinc-600">{it.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Cross-links -->
  {crossLinksHeading && crossLinks.length > 0 && (
    <section class="bg-zinc-100 py-16">
      <div class="mx-auto max-w-4xl px-4">
        <h2 class="text-xl font-semibold tracking-tight text-zinc-900">
          {crossLinksHeading}
        </h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {crossLinks.map((link) => (
            <a
              href={link.href}
              class="rounded-full border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 hover:border-red-400 hover:text-red-700 transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-zinc-50 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl">
        {ctaHeading}
      </h2>
      <p class="mt-4 text-base leading-relaxed text-zinc-600">{ctaBody}</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href={ctaHref}
          class="rounded-full bg-red-600 px-7 py-3 text-sm font-semibold text-white shadow-sm hover:bg-red-500 transition-colors"
        >
          {ctaButtonLabel}
        </a>
        <a
          href="https://wa.me/6285348674326"
          class="rounded-full border border-emerald-300 px-7 py-3 text-sm font-semibold text-emerald-700 hover:bg-emerald-50 transition-colors"
        >
          WhatsApp
        </a>
      </div>
    </div>
  </section>

</main>
