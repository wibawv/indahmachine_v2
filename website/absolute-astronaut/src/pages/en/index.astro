---
import Layout from "../../layouts/Layout.astro";
import { products, families } from "../../data/products";
import { trimMetaDescription } from "../../utils/seo";
import { siteUrl } from "../../utils/siteUrl";

const description = trimMetaDescription(
  "Industrial machinery distributor Medan, Indonesia: alternators for generators and genset, electric motors, power presses. Serving Jakarta, Surabaya, and Indonesia. Contact for quote."
);

const familyCounts = families.map((family) => ({
  family,
  count: products.filter((p) => p.family === family).length,
}));

const familyMeta: Record<string, { image: string; alt: string; description: string }> = {
  "Alternator": {
    image: "base44_product_image/alternator_icon.webp",
    alt: "Alternator",
    description: "Generator-ready alternators for genset and backup power — reliable prime and standby applications.",
  },
  "Electric Motor": {
    image: "base44_product_image/electric-motor-icon.avif",
    alt: "Electric Motor",
    description: "Efficient motors for pumps, fans, compressors, and production lines.",
  },
  "Power Press": {
    image: "base44_product_image/power-press-icon.webp",
    alt: "Power Press",
    description: "Inclinable power presses for metal stamping and fabrication.",
  },
};
---

<Layout
  lang="en"
  title="Indah Machine – Industrial Machinery Distributor"
  description={description}
  canonicalPath="/en/"
  localizedPaths={{ en: "/en/", id: "/id/" }}
>
  <main class="text-zinc-900">

    <!-- Section 1: Hero -->
    <section class="bg-zinc-50 py-20">
      <div class="mx-auto max-w-6xl px-4">
        <div class="grid items-center gap-12 md:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)]">
          <header class="space-y-6">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-red-600">
              Medan, Indonesia
            </p>
            <h1 class="text-5xl font-semibold leading-tight tracking-tight text-zinc-900 sm:text-6xl">
              Reliable power and machinery for your projects.
            </h1>
            <p class="max-w-lg text-lg text-zinc-600">
              Alternators, electric motors, and power presses for genset and generator projects, production lines, and metalworking — distributor based in Medan, serving Jakarta, Surabaya, and Indonesia.
            </p>
            <div class="flex flex-wrap gap-3 pt-2">
              <a
                href={siteUrl("en/products")}
                class="rounded-full bg-red-600 px-7 py-3 text-sm font-semibold text-white shadow-sm hover:bg-red-500 transition-colors"
              >
                View Products
              </a>
              <a
                href={siteUrl("en/contact")}
                class="rounded-full border border-red-300 px-7 py-3 text-sm font-semibold text-red-700 hover:bg-red-50 transition-colors"
              >
                Contact for Quote
              </a>
            </div>
          </header>

          <div class="relative min-h-[55vh] overflow-hidden rounded-2xl border border-red-100 bg-zinc-100 md:min-h-[50vh]">
            <img
              src={siteUrl("base44_product_image/frontpage_1.png")}
              alt="Indah Machine — industrial machinery"
              class="absolute inset-0 h-full w-full object-cover object-center"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Product Families -->
    <section class="bg-zinc-100 py-20">
      <div class="mx-auto max-w-6xl px-4">
        <div class="mb-10 space-y-2">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-red-600">Product Families</p>
          <h2 class="text-3xl font-semibold tracking-tight text-zinc-900">
            Three families. One trusted distributor.
          </h2>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {familyCounts.map(({ family, count }) => {
            const meta = familyMeta[family];
            return (
              <a
                href={siteUrl(`en/products?family=${encodeURIComponent(family)}`)}
                class="group flex flex-col overflow-hidden rounded-2xl border border-red-100 bg-zinc-50 shadow-sm transition hover:border-red-300 hover:shadow-md"
              >
                <div class="flex h-40 items-center justify-center bg-zinc-100 p-6">
                  <img
                    src={siteUrl(meta.image)}
                    alt={meta.alt}
                    class="h-28 w-auto object-contain transition group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="flex flex-1 flex-col justify-between p-5">
                  <div class="space-y-1.5">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-500">
                      Product Family
                    </p>
                    <h3 class="text-lg font-semibold text-zinc-900">{family}</h3>
                    <p class="text-sm text-zinc-500">{meta.description}</p>
                  </div>
                  <div class="mt-4 flex items-center justify-between">
                    <span class="text-xs text-zinc-400">{count} model{count === 1 ? "" : "s"} in catalog</span>
                    <span class="text-xs font-semibold text-red-600 group-hover:text-red-500">
                      View products →
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Section 3: Trust Band -->
    <section class="bg-zinc-900 py-20">
      <div class="mx-auto max-w-3xl px-4 text-center">
        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-red-400">
          Why Choose Indah Machine
        </p>
        <h2 class="text-3xl font-semibold leading-tight tracking-tight text-white sm:text-4xl">
          Your Trusted Partner in Industrial Solutions
        </h2>
        <p class="mt-5 text-base leading-relaxed text-zinc-400">
          With over 50 years of experience, Indah Machine is dedicated to providing high-quality, reliable industrial equipment. We build lasting partnerships by delivering excellence and comprehensive support to help your business thrive across Medan, Jakarta, and Surabaya.
        </p>
        <a
          href={siteUrl("en/about")}
          class="mt-8 inline-flex items-center gap-1 text-sm font-semibold text-red-400 hover:text-red-300 transition-colors"
        >
          Learn more about us →
        </a>
      </div>
    </section>

    <!-- Section 4: Value Pillars -->
    <section class="bg-zinc-50 py-20">
      <div class="mx-auto max-w-6xl px-4">
        <div class="mb-10 space-y-2 text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-red-600">Our Commitment</p>
          <h2 class="text-3xl font-semibold tracking-tight text-zinc-900">
            Built on quality, expertise, and reliability.
          </h2>
        </div>
        <div class="grid gap-8 md:grid-cols-3">
          <!-- Pillar 1 -->
          <div class="space-y-4 rounded-2xl border border-zinc-100 p-7 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red-50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
            </div>
            <div class="space-y-1.5">
              <h3 class="text-base font-semibold text-zinc-900">Premium Quality Products</h3>
              <p class="text-sm leading-relaxed text-zinc-500">
                Sourced from world-class manufacturers to ensure peak performance and long service life in demanding conditions.
              </p>
            </div>
          </div>

          <!-- Pillar 2 -->
          <div class="space-y-4 rounded-2xl border border-zinc-100 p-7 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red-50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />
              </svg>
            </div>
            <div class="space-y-1.5">
              <h3 class="text-base font-semibold text-zinc-900">Expert Technical Support</h3>
              <p class="text-sm leading-relaxed text-zinc-500">
                Our knowledgeable team is ready to assist with sizing, installation, commissioning, and technical advisory for your specific needs.
              </p>
            </div>
          </div>

          <!-- Pillar 3 -->
          <div class="space-y-4 rounded-2xl border border-zinc-100 p-7 shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-red-50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            <div class="space-y-1.5">
              <h3 class="text-base font-semibold text-zinc-900">Commitment to Reliability</h3>
              <p class="text-sm leading-relaxed text-zinc-500">
                Durable machinery built to withstand demanding industrial environments, backed by responsive after-sales service.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 5: Company Photo + Story -->
    <section class="bg-zinc-100 py-20">
      <div class="mx-auto max-w-6xl px-4">
        <div class="grid items-center gap-12 md:grid-cols-2">
          <div class="overflow-hidden rounded-2xl border border-zinc-200">
            <img
              src={siteUrl("base44_product_image/imc_store.jpg")}
              alt="Indah Machine store in Medan"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="space-y-5">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-red-600">About Us</p>
            <h2 class="text-3xl font-semibold tracking-tight text-zinc-900">
              Serving industry in Medan, Jakarta, and Surabaya.
            </h2>
            <p class="text-base leading-relaxed text-zinc-600">
              From our location at Jln. Mangkubumi No. 12, Medan 20151, we supply and support local and regional customers with reliable alternators, electric motors, and power presses. Beyond equipment, we offer installation, commissioning, and technical advisory to ensure the right machine for your load and site conditions.
            </p>
            <div class="flex flex-wrap gap-3 pt-2">
              <a
                href={siteUrl("en/about")}
                class="rounded-full border border-zinc-300 px-6 py-2.5 text-sm font-semibold text-zinc-700 hover:border-red-300 hover:text-red-700 transition-colors"
              >
                Our Story
              </a>
              <a
                href={siteUrl("en/products")}
                class="rounded-full bg-red-600 px-6 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-red-500 transition-colors"
              >
                View Products
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
