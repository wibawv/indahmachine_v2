---
import Layout from "../../layouts/Layout.astro";
import { seriesListingProducts, families } from "../../data/products";
import { trimMetaDescription } from "../../utils/seo";

const description = trimMetaDescription(
  "Browse alternators for generators and genset, electric motors, and power presses. Industrial machinery distributor Indonesia — based in Medan, serving Jakarta, Surabaya, and nationwide. Contact for quote."
);
---

<Layout
  lang="en"
  title="Indah Machine – Products"
  description={description}
  canonicalPath="/en/products"
  localizedPaths={{ en: "/en/products", id: "/id/products" }}
>
  <main class="bg-zinc-100 text-zinc-900">
    <section class="mx-auto flex max-w-6xl flex-col gap-10 px-4 py-16">
      <header class="space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-red-600">Catalog</p>
        <h1 class="text-4xl font-semibold tracking-tight text-zinc-900">
          Products
        </h1>
        <p class="max-w-2xl text-base text-zinc-600">
          Browse alternators for generators and genset, electric motors, and power presses. Distributor in Medan — we support customers in Jakarta, Surabaya, and across Indonesia. Contact us for quotation and sizing help.
        </p>
      </header>

      <nav class="flex flex-wrap items-center gap-2">
        <a
          href="/en/products"
          data-family-btn="all"
          class="rounded-full border px-4 py-1.5 text-xs font-medium transition-colors border-zinc-300 text-zinc-600 hover:border-red-400 hover:text-red-700"
        >
          All families
        </a>
        {families.map((family) => (
          <a
            href={`/en/products?family=${encodeURIComponent(family)}`}
            data-family-btn={family}
            class="rounded-full border px-4 py-1.5 text-xs font-medium transition-colors border-zinc-300 text-zinc-600 hover:border-red-400 hover:text-red-700"
          >
            {family}
          </a>
        ))}
      </nav>

      <section class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {seriesListingProducts.map((p) => (
          <a
            href={`/en/products/${encodeURIComponent(p.id)}`}
            data-family={p.family}
            class="group flex flex-col overflow-hidden rounded-2xl border border-zinc-200 shadow-sm transition hover:border-red-300 hover:shadow-md"
          >
            <div class="relative w-full overflow-hidden bg-white">
              <div class="flex aspect-[4/3] w-full items-center justify-center p-2 sm:p-2.5">
                <img
                  src={`/${p.image_path}`}
                  alt={p.name}
                  class="max-h-full max-w-full object-contain object-center transition duration-300 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </div>
            </div>
            <div class="flex flex-1 flex-col justify-between bg-zinc-100 p-5">
              <div class="space-y-1">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-red-500">
                  {p.family} · {p.series}
                </p>
                <h2 class="text-base font-semibold text-zinc-900 line-clamp-2">
                  {p.name}
                </h2>
              </div>
              <p class="mt-3 text-xs leading-relaxed text-zinc-500 line-clamp-3">
                {p.description}
              </p>
              <p class="mt-4 text-xs font-semibold text-red-600 group-hover:text-red-500">
                View details →
              </p>
            </div>
          </a>
        ))}
      </section>
    </section>
  </main>

  <script is:inline>
    (function () {
      const params = new URLSearchParams(window.location.search);
      const active = params.get("family");

      document.querySelectorAll("[data-family]").forEach((card) => {
        card.classList.toggle(
          "hidden",
          active !== null && card.dataset.family !== active
        );
      });

      document.querySelectorAll("[data-family-btn]").forEach((btn) => {
        const isActive =
          active === null
            ? btn.dataset.familyBtn === "all"
            : btn.dataset.familyBtn === active;
        btn.classList.toggle("border-red-500", isActive);
        btn.classList.toggle("bg-red-50", isActive);
        btn.classList.toggle("text-red-700", isActive);
        btn.classList.toggle("border-zinc-300", !isActive);
        btn.classList.toggle("text-zinc-600", !isActive);
      });
    })();
  </script>
</Layout>
