---
import Layout from "../../layouts/Layout.astro";
import { trimMetaDescription } from "../../utils/seo";
import { siteUrl } from "../../utils/siteUrl";

const description = trimMetaDescription(
  "About Indah Machine: industrial machinery distributor in Medan supplying alternators for genset and generators, electric motors, and power presses. Serving customers in Jakarta, Surabaya, and Indonesia."
);
---

<Layout
  lang="en"
  title="Indah Machine – About (EN)"
  description={description}
  canonicalPath="/en/about"
  localizedPaths={{ en: "/en/about", id: "/id/about" }}
>
  <main class="bg-zinc-100 text-zinc-900">
    <section class="mx-auto flex max-w-6xl flex-col gap-12 px-4 py-16">

      <!-- Header -->
      <header>
        <h1 class="text-3xl font-semibold tracking-tight text-red-700">
          About Indah Machine
        </h1>
      </header>

      <!-- Intro + Contact sidebar -->
      <section class="grid gap-8 md:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)]">
        <div class="space-y-4 text-sm text-zinc-700">
          <p>
            Indah Machine is a machinery distributor based in Medan, supplying alternators for generators and genset, electric motors, and power presses for industrial use — with customers across Jakarta, Surabaya, and Indonesia.
          </p>
          <p>
            From our location at Jln. Mangkubumi No. 12, Medan 20151, we support customers
            across Medan, Jakarta, and Surabaya with reliable products, technical guidance,
            and after-sales service.
          </p>
          <p>
            We focus on three product families:
          </p>
          <ul class="list-disc space-y-1 pl-4">
            <li>Alternators for generator sets and backup power systems</li>
            <li>Electric motors for pumps, fans, compressors, and general machinery</li>
            <li>Power presses for metal stamping and fabrication</li>
          </ul>
          <p>
            Beyond supplying equipment, we can assist with installation, commissioning, and
            technical advisory to help you choose the right machine for your load, duty cycle, and
            site conditions.
          </p>
        </div>

        <aside class="space-y-4 rounded-xl border border-red-100 bg-zinc-50 p-5 text-sm shadow-sm">
          <h2 class="text-sm font-semibold text-red-700">Contact details</h2>
          <div class="space-y-2 text-zinc-700">
            <p>
              <span class="font-medium text-zinc-900">Address:</span><br />
              Jln. Mangkubumi No. 12<br />
              Medan 20151, North Sumatra, Indonesia
            </p>
            <p>
              <span class="font-medium text-zinc-900">Email:</span><br />
              indahmachine@gmail.com
            </p>
            <p>
              <span class="font-medium text-zinc-900">Phone:</span><br />
              +62 85-34-867-4326<br />
              +62 81-630-6825
            </p>
            <p>
              <span class="font-medium text-zinc-900">WhatsApp:</span><br />
              +62 853-4867-4326
            </p>
          </div>
          <a
            href={siteUrl("en/contact")}
            class="inline-flex rounded-full bg-emerald-500 px-5 py-2 text-xs font-semibold text-slate-950 shadow-sm hover:bg-emerald-400"
          >
            Contact for Quote
          </a>
        </aside>
      </section>

      <!-- Our Story -->
      <section class="space-y-8">
        <div class="grid gap-8 md:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)]">
          <div class="space-y-4 text-sm text-zinc-700">
            <h2 class="text-2xl font-semibold text-zinc-900">Our Story</h2>
            <p>
              Founded in 1973, Indah Machine began as a small trading company in Medan with a
              vision to provide Indonesian manufacturers with access to world-class industrial
              equipment. What started as a humble operation has grown into one of North Sumatra's
              most trusted suppliers of industrial machinery.
            </p>
            <p>
              Our commitment to quality, reliability, and customer service has earned us
              partnerships with leading manufacturers across diverse industries. Today, we serve
              customers across three of Indonesia's major industrial cities — Medan (North Sumatra),
              Jakarta Pusat, and Surabaya — helping businesses of all sizes find the right machines
              to keep their operations running.
            </p>
            <p>
              We continue to expand our capabilities while maintaining the personal touch and
              attention to detail that has defined our company for over five decades.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-4 rounded-xl border border-red-100 bg-red-50 p-6">
            <div class="flex flex-col items-center gap-1 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span class="text-2xl font-bold text-red-700">1973</span>
              <span class="text-xs text-zinc-600">Est. — Over 50 Years</span>
            </div>
            <div class="flex flex-col items-center gap-1 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-2xl font-bold text-red-700">3 Cities</span>
              <span class="text-xs text-zinc-600">Medan · Jakarta · Surabaya</span>
            </div>
            <div class="flex flex-col items-center gap-1 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span class="text-2xl font-bold text-red-700">24/7</span>
              <span class="text-xs text-zinc-600">Support via WhatsApp</span>
            </div>
            <div class="flex flex-col items-center gap-1 text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
              <span class="text-2xl font-bold text-red-700">3 Families</span>
              <span class="text-xs text-zinc-600">Alternator · Motor · Press</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Our Values -->
      <section class="space-y-8">
        <div class="text-center space-y-2">
          <h2 class="text-2xl font-semibold text-zinc-900">Our Values</h2>
          <p class="text-sm text-zinc-500">The principles that guide everything we do and drive our commitment to excellence</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <div class="flex flex-col items-center gap-3 rounded-xl bg-white p-6 text-center shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <h3 class="text-sm font-semibold text-zinc-900">Quality First</h3>
            <p class="text-xs text-zinc-600">We never compromise on quality, ensuring every product meets international and SNI standards.</p>
          </div>
          <div class="flex flex-col items-center gap-3 rounded-xl bg-white p-6 text-center shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-sm font-semibold text-zinc-900">Customer Focus</h3>
            <p class="text-xs text-zinc-600">Our customers' success is our success. We provide comprehensive pre- and post-sales technical support.</p>
          </div>
          <div class="flex flex-col items-center gap-3 rounded-xl bg-white p-6 text-center shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-sm font-semibold text-zinc-900">Innovation</h3>
            <p class="text-xs text-zinc-600">Continuously expanding our product range and services to meet the evolving needs of Indonesian industry.</p>
          </div>
          <div class="flex flex-col items-center gap-3 rounded-xl bg-white p-6 text-center shadow-sm">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-red-50">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-sm font-semibold text-zinc-900">Reliability</h3>
            <p class="text-xs text-zinc-600">Building long-term partnerships through consistent supply, dependable performance, and responsive service.</p>
          </div>
        </div>
      </section>

      <!-- Quality & Certifications -->
      <section class="grid gap-8 md:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)]">
        <div class="space-y-5">
          <h2 class="text-2xl font-semibold text-zinc-900">Quality &amp; Certifications</h2>
          <p class="text-sm text-zinc-700">
            We maintain the highest standards of quality and compliance. Our products are sourced
            from manufacturers with internationally recognised certifications, ensuring that every
            machine we supply meets the safety and performance requirements of Indonesian industry.
          </p>
          <ul class="space-y-3 text-sm text-zinc-700">
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              CE Marking Compliance (European-standard products)
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Indonesian National Standards (SNI)
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Products sourced from ISO-certified manufacturers
            </li>
          </ul>
        </div>

        <div class="rounded-xl border border-red-100 bg-zinc-50 p-6 shadow-sm">
          <h3 class="mb-4 text-sm font-semibold text-red-700">Why Choose Us?</h3>
          <ul class="space-y-4 text-sm">
            <li class="space-y-0.5">
              <p class="font-medium text-zinc-900">Expert Technical Support</p>
              <p class="text-xs text-zinc-500">Pre- and post-sales technical support across Medan, Jakarta, and Surabaya.</p>
            </li>
            <li class="space-y-0.5">
              <p class="font-medium text-zinc-900">Contact for Quote</p>
              <p class="text-xs text-zinc-500">Competitive pricing tailored to your application and volume.</p>
            </li>
            <li class="space-y-0.5">
              <p class="font-medium text-zinc-900">Fast Delivery</p>
              <p class="text-xs text-zinc-500">Efficient logistics across Medan, Jakarta, and Surabaya.</p>
            </li>
            <li class="space-y-0.5">
              <p class="font-medium text-zinc-900">Warranty Coverage</p>
              <p class="text-xs text-zinc-500">Comprehensive warranty on all products supplied.</p>
            </li>
          </ul>
        </div>
      </section>

    </section>
  </main>
</Layout>
