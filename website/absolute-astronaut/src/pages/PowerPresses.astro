---
const site = Astro.site ?? new URL("https://indahmachine.com/");
const target = "/en/products/?family=Power%20Press";
const canonicalHref = new URL("en/products/", site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Indah Machine — Power Presses</title>
    <link rel="canonical" href={canonicalHref} />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>
      Redirecting to <a href={target}>Power Press catalog</a>.
    </p>
  </body>
</html>
