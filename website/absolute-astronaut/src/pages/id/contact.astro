---
import Layout from "../../layouts/Layout.astro";
import { trimMetaDescription, localBusinessJsonLd } from "../../utils/seo";

const site = Astro.site ?? new URL("https://indahmachine.com/");
const description = trimMetaDescription(
  "Kontak Indah Machine Medan untuk penawaran alternator, proyek genset dan generator, motor listrik, dan power press. Melayani Jakarta, Surabaya, dan seluruh Indonesia."
);
const jsonLd = [JSON.stringify(localBusinessJsonLd(site))];
---

<Layout
  lang="id"
  title="Indah Machine – Kontak (ID)"
  description={description}
  canonicalPath="/id/contact"
  localizedPaths={{ en: "/en/contact", id: "/id/contact" }}
  jsonLd={jsonLd}
>
  <main class="bg-zinc-100 text-zinc-900">
    <section class="mx-auto flex max-w-6xl flex-col gap-12 px-4 py-16">
      <header class="space-y-3">
        <h1 class="text-3xl font-semibold tracking-tight text-red-700">
          Kontak &amp; Penawaran
        </h1>
        <p class="max-w-2xl text-sm text-zinc-700">
          Hubungi kami untuk penawaran dan bantuan kapasitas untuk alternator, aplikasi genset dan generator, motor listrik, dan power press — kantor di Medan; pelanggan di Jakarta, Surabaya, dan nasional.
        </p>
      </header>

      <section class="grid gap-8 md:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] md:items-start">
        <form class="h-fit space-y-4 rounded-xl border border-red-100 bg-zinc-50 p-5 text-sm shadow-sm">
          <div class="grid gap-4 md:grid-cols-2">
            <div class="space-y-1">
              <label class="block text-xs font-medium text-red-700" for="name">
                Nama
              </label>
              <input
                id="name"
                type="text"
                class="w-full rounded-md border border-zinc-300 bg-zinc-50 px-3 py-2 text-sm text-zinc-900 outline-none focus:border-red-400"
                placeholder="Nama Anda"
              />
            </div>
            <div class="space-y-1">
              <label class="block text-xs font-medium text-red-700" for="company">
                Perusahaan
              </label>
              <input
                id="company"
                type="text"
                class="w-full rounded-md border border-zinc-300 bg-zinc-50 px-3 py-2 text-sm text-zinc-900 outline-none focus:border-red-400"
                placeholder="Nama perusahaan"
              />
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="space-y-1">
              <label class="block text-xs font-medium text-red-700" for="phone">
                Telepon / WhatsApp
              </label>
              <input
                id="phone"
                type="text"
                class="w-full rounded-md border border-zinc-300 bg-zinc-50 px-3 py-2 text-sm text-zinc-900 outline-none focus:border-red-400"
                placeholder="+62..."
              />
            </div>
            <div class="space-y-1">
              <label class="block text-xs font-medium text-red-700" for="email">
                Email
              </label>
              <input
                id="email"
                type="email"
                class="w-full rounded-md border border-zinc-300 bg-zinc-50 px-3 py-2 text-sm text-zinc-900 outline-none focus:border-red-400"
                placeholder="anda@example.com"
              />
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="space-y-1">
              <label class="block text-xs font-medium text-red-700" for="product">
                Produk / Seri
              </label>
              <input
                id="product"
                type="text"
                class="w-full rounded-md border border-zinc-300 bg-zinc-50 px-3 py-2 text-sm text-zinc-900 outline-none focus:border-red-400"
                placeholder="UCW, TZH, MECC Y2/Y23, J23/JC23..."
              />
            </div>
            <div class="space-y-1">
              <label class="block text-xs font-medium text-red-700" for="capacity">
                Kapasitas yang dibutuhkan (kW/kVA)
              </label>
              <input
                id="capacity"
                type="text"
                class="w-full rounded-md border border-zinc-300 bg-zinc-50 px-3 py-2 text-sm text-zinc-900 outline-none focus:border-red-400"
                placeholder="contoh: 250 kVA, 30 kW"
              />
            </div>
          </div>

          <div class="space-y-1">
            <label class="block text-xs font-medium text-red-700" for="message">
              Pesan / Detail aplikasi
            </label>
            <textarea
              id="message"
              rows={4}
              class="w-full rounded-md border border-zinc-300 bg-zinc-50 px-3 py-2 text-sm text-zinc-900 outline-none focus:border-red-400"
              placeholder="Jelaskan aplikasi, lokasi, dan target waktu Anda."
            />
          </div>

          <p class="text-xs text-zinc-600">
            Harga tersedia berdasarkan permintaan. Kami akan membalas permintaan Anda secepat mungkin.
          </p>

          <button
            type="submit"
            class="inline-flex rounded-full bg-red-600 px-6 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500"
          >
            Kirim permintaan
          </button>
        </form>

        <aside class="flex flex-col gap-5 text-sm text-zinc-700">
          <!-- Telepon -->
          <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-sm">
            <div class="flex gap-4">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-blue-600">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div class="min-w-0 space-y-2">
                <h2 class="text-base font-semibold text-zinc-900">Telepon</h2>
                <p class="space-y-1 leading-relaxed">
                  <a href="tel:+6285348674326" class="block text-zinc-700 hover:text-red-700">+62 85-34-867-4326</a>
                  <a href="tel:+62816306825" class="block text-zinc-700 hover:text-red-700">+62 81-630-6825</a>
                </p>
              </div>
            </div>
          </div>

          <!-- Email -->
          <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-sm">
            <div class="flex gap-4">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-emerald-50 text-emerald-600">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <div class="min-w-0 space-y-2">
                <h2 class="text-base font-semibold text-zinc-900">Email</h2>
                <a href="mailto:indahmachine@gmail.com" class="break-all text-zinc-700 hover:text-red-700">
                  indahmachine@gmail.com
                </a>
              </div>
            </div>
          </div>

          <!-- Alamat -->
          <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-sm">
            <div class="flex gap-4">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-red-50 text-red-600">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div class="min-w-0 space-y-3">
                <h2 class="text-base font-semibold text-zinc-900">Alamat</h2>
                <p class="leading-relaxed text-zinc-700">
                  Jln. Mangkubumi No. 12<br />
                  Medan 20151, Sumatera Utara, Indonesia
                </p>
                <a
                  href="https://www.google.com/maps/place/Indah+Machine/@3.581397,98.681437,18z"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex text-sm font-medium text-red-700 hover:text-red-600"
                >
                  Buka di Google Maps
                </a>
              </div>
            </div>
          </div>

          <!-- Jam operasional -->
          <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-sm">
            <div class="flex gap-4">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-violet-50 text-violet-600">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="min-w-0 space-y-3">
                <h2 class="text-base font-semibold text-zinc-900">Jam Operasional</h2>
                <ul class="space-y-2 leading-relaxed text-zinc-700">
                  <li><span class="font-medium text-zinc-800">Senin – Jumat:</span> 08.00 – 18.00</li>
                  <li><span class="font-medium text-zinc-800">Sabtu:</span> 08.00 – 14.00</li>
                  <li><span class="font-medium text-zinc-800">Minggu:</span> Tutup</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- WhatsApp CTA -->
          <div class="rounded-xl border border-emerald-200 bg-emerald-50/80 p-5 shadow-sm">
            <div class="flex gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                </svg>
              </div>
              <div class="min-w-0 flex-1 space-y-3">
                <h2 class="text-base font-semibold text-zinc-900">Butuh Bantuan Cepat?</h2>
                <p class="leading-relaxed text-zinc-700">
                  Chat dengan kami di WhatsApp untuk bantuan segera.
                </p>
                <a
                  href="https://wa.me/6285348674326"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500"
                >
                  Mulai Chat WhatsApp
                </a>
              </div>
            </div>
          </div>

          <!-- Peta -->
          <div class="overflow-hidden rounded-xl border border-zinc-200 bg-white p-5 shadow-sm">
            <h2 class="mb-3 text-base font-semibold text-zinc-900">Lokasi Kami</h2>
            <div class="overflow-hidden rounded-lg border border-zinc-200">
              <iframe
                title="Indah Machine di Google Maps"
                src="https://maps.google.com/maps?q=3.581397,98.681437&t=&z=17&ie=UTF8&iwloc=&output=embed"
                width="100%"
                height="220"
                class="block min-h-[220px] w-full border-0"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              />
            </div>
            <a
              href="https://www.google.com/maps/place/Indah+Machine/@3.581397,98.681437,18z"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3 inline-flex text-sm font-medium text-red-700 hover:text-red-600"
            >
              Buka di Google Maps
            </a>
          </div>
        </aside>
      </section>
    </section>
  </main>
</Layout>

